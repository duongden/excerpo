{
  "manifest_version": 3,
  "name": "Excerpo",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage",
    "webNavigation",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.17k.com/*",
    "https://17k.com/*",
    "https://www.22biqu.com/*",
    "https://22biqu.com/*",
    "https://uukanshu.cc/*",
    "https://www.uukanshu.cc/*",
    "https://www.jjwxc.net/*",
    "http://www.jjwxc.net/*",
    "https://www.qidian.com/*",
    "https://qidian.com/*",
    "https://www.biquge.tw/*",
    "https://www.52shuku.net/*",
    "https://fanqienovel.com/*",
    "https://*.fanqienovel.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://tessdata.projectnaptha.com/*",
    "https://html2canvas.hertzen.com/*",
    "https://*.69shuba.com/*",
    "https://*.69shuba.cx/*",
    "https://*.69shux.com/*",
    "https://*.novel543.com/*",
    "https://example.com/*",
    "https://kakuyomu.jp/*",
    "https://*.kakuyomu.jp/*",
    "https://ncode.syosetu.com/*",
    "https://*.syosetu.com/*",
    "https://www.pixiv.net/*",
    "https://*.pixiv.net/*",
    "https://*.ixdzs8.com/*",
    "https://*.ixdzs.com/*",
    "https://book.qq.com/*",
    "https://*.book.qq.com/*",
    "https://*.hetushu.com/*",
    "https://*.xbanxia.cc/*",
    "https://*.xbanxia.com/*",
    "https://*.69shumi.net/*",
    "https://*.69shumi.com/*",
    "https://*.syosetu.org/*",
    "https://www.xbiquge.com/*",
    "https://xbiquge.com/*",
    "https://www.23qb.net/*",
    "https://23qb.net/*",
    "https://www.shubaow.org/*",
    "https://shubaow.org/*",
    "https://www.sto55.com/*",
    "https://sto55.com/*",
    "https://www.sto9.com/*",
    "https://sto9.com/*",
    "https://www.twkan.com/*",
    "https://twkan.com/*",
    "https://www.ttkan.co/*",
    "https://ttkan.co/*",
    "https://www.wa01.com/*",
    "https://wa01.com/*",
    "https://www.royalroad.com/*",
    "https://royalroad.com/*",
    "https://www.scribblehub.com/*",
    "https://scribblehub.com/*"
    ,
    "https://www.archiveofourown.org/*",
    "https://archiveofourown.org/*",
    "https://www.po18.tw/*",
    "https://po18.tw/*",
    "https://novellunar.com/*",
    "https://*.novellunar.com/*",
    "https://img.novellunar.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "tesseract/*"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.novel543.com/*"
      ],
      "js": [
        "scripts/novel543-content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.xbiquge.com/*",
        "https://xbiquge.com/*"
      ],
      "js": [
        "scripts/xbiquge-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}