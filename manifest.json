{
  "manifest_version": 3,
  "name": "Excerpo",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage",
    "webNavigation",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.17k.com/*",
    "https://17k.com/*",
    "https://www.22biqu.com/*",
    "https://22biqu.com/*",
    "https://uukanshu.cc/*",
    "https://www.uukanshu.cc/*",
    "https://www.jjwxc.net/*",
    "http://www.jjwxc.net/*",
    "https://www.qidian.com/*",
    "https://qidian.com/*",
    "https://www.biquge.tw/*",
    "https://www.52shuku.net/*",
    "https://fanqienovel.com/*",
    "https://*.fanqienovel.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://tessdata.projectnaptha.com/*",
    "https://html2canvas.hertzen.com/*",
    "https://*.69shuba.com/*",
    "https://*.69shuba.cx/*",
    "https://*.69shux.com/*",
    "https://*.novel543.com/*",
    "https://example.com/*",
    "https://kakuyomu.jp/*",
    "https://*.kakuyomu.jp/*",
    "https://ncode.syosetu.com/*",
    "https://*.syosetu.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["tesseract/*"],
      "matches": ["*://*/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.novel543.com/*"],
      "js": ["scripts/novel543-content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}